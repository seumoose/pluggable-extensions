{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "java",
      "name": "Java Application",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "console": "internalConsole",
      "mainClass": "com.seumoose.launcher.ApplicationLauncher",
      "projectName": "launcher",
      "env": {
        "CONFIGURATION_ROOT_PATH": "${workspaceFolder}/config",
        "EXTENSION_ROOT_PATH": "${workspaceFolder}/runtime-extensions"
      }
    }
  ]
}
